# ═══════════════════════════════════════════════════════════════
#  AI_Agent_Basic — Environment Variables Template
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el archivo .env a un repositorio.
# ═══════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_TOKEN=8503726937:AAHXLQFzmsWOve0H0BBWJug4q2v-RszKKl8

# ── LLM Provider ─────────────────────────────────────────────
# API Key del proveedor de LLM (OpenAI, Groq, OpenRouter, etc.)
LLM_API_KEY=your_llm_api_key_here

# URL base del proveedor (OpenAI-compatible)
# Ejemplos:
#   OpenAI:     https://api.openai.com/v1
#   Groq:       https://api.groq.com/openai/v1
#   OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.openai.com/v1

# Modelo a usar
# Ejemplos: gpt-4o-mini | gpt-4o | llama-3.1-70b-versatile | gemini-pro
LLM_MODEL=gpt-4o-mini

# ── Bot Settings ──────────────────────────────────────────────
# Máximo de mensajes a recordar por conversación (memoria)
MAX_HISTORY=10
