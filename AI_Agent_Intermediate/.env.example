# Telegram Bot
TELEGRAM_TOKEN=tu_token_de_telegram_aqui

# LLM Provider (NVIDIA Nemotron o Llama 3)
LLM_API_KEY=tu_api_key_aqui
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.3-70b-instruct

# OpenAI Embeddings (Recomendado para generar vectores)
OPENAI_API_KEY=tu_api_key_de_openai_para_embeddings

# Supabase (Vector Database)
SUPABASE_URL=https://sddbcqleylbyoflakfsw.supabase.co
# IMPORTANTE: Utiliza la Service Role Key para poder insertar datos, no la anon key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Limites de Memoria
MAX_HISTORY=20
